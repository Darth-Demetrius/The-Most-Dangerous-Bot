#!/bin/sh

PIDS=$(pgrep -f "python -u bot/main.py")

if [ -z "$PIDS" ]; then
	echo "Bot is not running."
	exit 0
fi

echo "Stopping bot (PID(s): $PIDS)..."
kill $PIDS

# Wait briefly for graceful shutdown.
for _ in 1 2 3 4 5; do
	if ! pgrep -f "python -u bot/main.py" >/dev/null; then
		echo "Bot stopped."
		exit 0
	fi
	sleep 1
done

REMAINING=$(pgrep -f "python -u bot/main.py")
if [ -n "$REMAINING" ]; then
	echo "Bot did not stop in time; forcing kill (PID(s): $REMAINING)..."
	kill -9 $REMAINING
fi

echo "Bot stopped."
